# Raktiniai zodziai / fragmentai (kableliais atskirti)
KEYWORDS=draudim

# Tikrinimo intervalas minutemis
CHECK_INTERVAL_MINUTES=60

# Maksimalus rezultatu skaicius per viena keyword
MAX_RESULTS_PER_KEYWORD=50

# Playwright headless rezimas
HEADLESS=true

# Kelias iki busenos katalogo (Railway Volume mount point, pvz. /data)
STATE_DIR=./state

# Ar paleisti i karto starto metu (pirma ciklas) - true/false
RUN_ON_START=true

# [RAILWAY-ONLY] Operacinis jungiklis DB isvalymui. Ijunk i `true` ir paleisk
# redeploy, kad $STATE_DIR/seen.sqlite3 butu istrintas pries scheduler'i.
# BUTINA isjungti atgal i `false` po vienkartinio wipe'o, kitaip kiekvienas
# restart'as trins DB (ir i Telegram is naujo atkeliaus 10 "nauju" pranesimu).
WIPE_DB_ON_START=false

# Log lygis (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- GitHub export (frontend'ui per GitHub Pages) ---
# Ar aktyvuoti export'a (true/false)
GITHUB_EXPORT_ENABLED=false
# Fine-grained PAT su teise rasyti i repo (Contents: Read & Write)
GITHUB_TOKEN=
# owner/repo, pvz. DITreneris/draudimas
GITHUB_REPO=
# Branch'as, kuriame saugomi duomenys (paprastai main)
GITHUB_BRANCH=main
# Kelias repo viduje - GitHub Pages is docs/ aplanko
GITHUB_FILE_PATH=docs/items.json
# Kiek naujausiu irasu export'inti i JSON
GITHUB_MAX_ITEMS=500

# --- Telegram asmeninis pranesimas (apie kiekviena nauja pirkima) ---
# Ar aktyvuoti siuntima i Telegram (true/false)
TELEGRAM_ENABLED=false
# Bot token'as is @BotFather, pvz. 1234567890:AAExxxYYY
TELEGRAM_BOT_TOKEN=
# Tavo asmeninis chat_id (gauk per @userinfobot arba getUpdates po /start)
TELEGRAM_CHAT_ID=

# --- Email (optional): Resend (HTTPS) ARBA SMTP ---
# Railway ir pan. daznai blokuoja outbound SMTP 587/465 — naudok Resend API.
# Ar siusti el. laiska apie kiekviena nauja pirkima (true/false)
EMAIL_ENABLED=false
# Resend API raktas (resend.com). Jei nurodytas kartu su EMAIL_FROM / EMAIL_TO,
# naudojamas Resend, ne SMTP.
RESEND_API_KEY=
# SMTP serveris (tik jei RESEND_API_KEY tuscias)
SMTP_HOST=
# 587 = STARTTLS (numatytasis), 465 = implicit SSL
SMTP_PORT=587
# Tuscias = be login (retai); dazniausiai pilnas el. pastas ar SMTP vartotojas
SMTP_USER=
SMTP_PASSWORD=
# Siuntejas (From), pvz. info@tavodomenas.lt
EMAIL_FROM=
# Gavejai kableliais, pvz. a@ex.com,b@ex.com
EMAIL_TO=
